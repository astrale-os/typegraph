{
  "$schema": "../node_modules/oxlint/configuration_schema.json",
  "rules": {
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-explicit-any": "warn",
    "consistent-type-imports": "warn",
    "no-console": "warn",
    "prefer-const": "error",
    "eqeqeq": [
      "error",
      "always"
    ]
  },
  "ignorePatterns": [
    "**/dist/**",
    "**/node_modules/**",
    "**/coverage/**",
    "**/*.js",
    "**/*.mjs",
    "**/*.cjs"
  ],
  "overrides": [
    {
      "files": [
        "**/__tests__/**/*.ts",
        "**/*.test.ts",
        "**/*.perf.ts",
        "**/*.bench.ts",
        "**/*.spec.ts"
      ],
      "rules": {
        "no-explicit-any": "off",
        "no-unused-vars": "off",
        "no-console": "off"
      }
    },
    {
      "files": ["**/scripts/**/*.ts"],
      "rules": {
        "no-console": "off",
        "no-explicit-any": "off"
      }
    },
    {
      "files": ["**/examples/**/*.ts"],
      "rules": {
        "no-console": "off",
        "no-explicit-any": "off"
      }
    }
  ]
}
