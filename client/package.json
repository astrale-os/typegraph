{
  "name": "@astrale/typegraph-client",
  "version": "0.2.4",
  "description": "Type-safe graph DSL for Cypher (Neo4j/Memgraph/FalkorDB)",
  "keywords": [
    "cypher",
    "database",
    "dsl",
    "falkordb",
    "graph",
    "memgraph",
    "neo4j",
    "query-builder",
    "type-safe",
    "typescript"
  ],
  "license": "MIT",
  "author": "Astrale",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrale-os/typegraph.git",
    "directory": "client"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup && tsgo -p tsconfig.build.json --declaration --emitDeclarationOnly",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:spec": "vitest run __tests__/spec",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "preinstall": "node .check-workspace.cjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "latest",
    "falkordb": "^6.4.1",
    "neo4j-driver": "^5.27.0",
    "tsup": "^8.3.5",
    "typescript": "~6.0.1-rc",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "neo4j-driver": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "neo4j-driver": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
