{
  "name": "@astrale/typegraph-core",
  "version": "0.1.0",
  "description": "Core schema DSL and AST for TypeGraph - lightweight package for schema definitions and tooling",
  "keywords": [
    "ast",
    "codegen",
    "cypher",
    "dsl",
    "graph",
    "schema",
    "type-safe",
    "typescript"
  ],
  "license": "MIT",
  "author": "Astrale",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrale-os/typegraph.git",
    "directory": "core"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./ast": {
      "types": "./src/ast/index.ts",
      "import": "./src/ast/index.ts",
      "default": "./src/ast/index.ts"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "import": "./src/errors/index.ts",
      "default": "./src/errors/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./schema": {
        "types": "./dist/schema/index.d.ts",
        "import": "./dist/schema/index.js",
        "require": "./dist/schema/index.cjs"
      },
      "./ast": {
        "types": "./dist/ast/index.d.ts",
        "import": "./dist/ast/index.js",
        "require": "./dist/ast/index.cjs"
      },
      "./errors": {
        "types": "./dist/errors/index.d.ts",
        "import": "./dist/errors/index.js",
        "require": "./dist/errors/index.cjs"
      },
      "./core": {
        "types": "./dist/core/index.d.ts",
        "import": "./dist/core/index.js",
        "require": "./dist/core/index.cjs"
      }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "latest",
    "tsup": "^8.3.5",
    "typescript": "~6.0.1-rc",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22"
  }
}
