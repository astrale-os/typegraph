{
  "name": "@astrale/typegraph-workspace",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrale-os/typegraph.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "node .check-workspace.cjs",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r run typecheck",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint --fix -c oxlint.json .",
    "format": "pnpm exec oxfmt --write .",
    "format:check": "pnpm exec oxfmt --check .",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "test:integration": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrale/typegraph-adapter-falkordb": "workspace:*",
    "@astrale/typegraph-client": "workspace:*",
    "@astrale/typegraph-core": "workspace:*"
  },
  "devDependencies": {
    "@astrale/commitlint-config": "jsr:@astrale/commitlint-config@~2.0.0",
    "@astrale/typescript-config": "jsr:@astrale/typescript-config@~1.1.0",
    "@commitlint/cli": "~20.3.1",
    "@commitlint/config-conventional": "~20.3.1",
    "@types/node": "~22.15.6",
    "@typescript/native-preview": "latest",
    "husky": "~9.1.7",
    "lint-staged": "~16.2.7",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "~6.0.1-rc",
    "vitest": "~3.2.2",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "oxlint --fix -c oxlint.json",
      "oxfmt --write"
    ],
    "*.{json,yml,yaml}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.28.0"
}
