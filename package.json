{
  "name": "@astrale/typegraph-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astrale-os/typegraph.git"
  },
  "scripts": {
    "preinstall": "node .check-workspace.cjs",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier --write .",
    "format:check": "pnpm exec prettier --check .",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "test:integration": "vitest run",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrale/typegraph": "workspace:*",
    "@astrale/typegraph-adapter-falkordb": "workspace:*",
    "@astrale/typegraph-core": "workspace:*"
  },
  "devDependencies": {
    "@astrale/commitlint-config": "jsr:@astrale/commitlint-config@~2.0.0",
    "@astrale/eslint-config": "jsr:@astrale/eslint-config@~2.0.0",
    "@astrale/prettier-config": "jsr:@astrale/prettier-config@~2.0.0",
    "@astrale/typescript-config": "jsr:@astrale/typescript-config@~1.1.0",
    "@commitlint/cli": "~20.3.1",
    "@commitlint/config-conventional": "~20.3.1",
    "@eslint/js": "~9.39.2",
    "eslint": "~9.39.2",
    "eslint-config-prettier": "~10.1.8",
    "husky": "~9.1.7",
    "lint-staged": "~16.2.7",
    "prettier": "~3.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.53.1",
    "@types/node": "~22.15.6",
    "vitest": "~3.2.2",
    "zod": "^4.3.6"
  },
  "prettier": "@astrale/prettier-config",
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
