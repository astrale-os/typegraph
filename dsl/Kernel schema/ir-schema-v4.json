{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel.astrale.ai/ir/v1",
  "title": "Kernel Schema IR v1",
  "description": "Serialized, fully-resolved graph schema. Single `classes` array with type discriminator.",

  "type": "object",
  "required": ["version", "meta", "builtin_scalars", "classes"],
  "additionalProperties": false,
  "properties": {

    "version": {
      "const": "1.0"
    },

    "meta": {
      "type": "object",
      "required": ["generated_at", "source_hash"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "source_hash": { "type": "string" }
      }
    },

    "extensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["uri", "imported_types"],
        "properties": {
          "uri": { "type": "string", "format": "uri" },
          "imported_types": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "builtin_scalars": {
      "type": "array",
      "items": { "type": "string" }
    },

    "type_aliases": {
      "type": "array",
      "items": { "$ref": "#/$defs/TypeAlias" }
    },

    "classes": {
      "description": "All class definitions: nodes (abstract or concrete) and edges.",
      "type": "array",
      "items": { "$ref": "#/$defs/ClassDef" }
    }
  },

  "$defs": {

    "ClassDef": {
      "oneOf": [
        { "$ref": "#/$defs/NodeDef" },
        { "$ref": "#/$defs/EdgeDef" }
      ]
    },

    "NodeDef": {
      "type": "object",
      "required": ["type", "name", "abstract", "attributes"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "node" },
        "name": { "type": "string" },
        "abstract": { "type": "boolean" },
        "implements": { "type": "array", "items": { "type": "string" } },
        "attributes": { "type": "array", "items": { "$ref": "#/$defs/Attribute" } },
        "origin": { "type": "string", "format": "uri" }
      }
    },

    "EdgeDef": {
      "type": "object",
      "required": ["type", "name", "endpoints", "attributes", "constraints"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "edge" },
        "name": { "type": "string" },
        "endpoints": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Endpoint" }
        },
        "attributes": { "type": "array", "items": { "$ref": "#/$defs/Attribute" } },
        "constraints": { "$ref": "#/$defs/EdgeConstraints" },
        "origin": { "type": "string", "format": "uri" }
      }
    },

    "TypeAlias": {
      "type": "object",
      "required": ["name", "underlying_type"],
      "properties": {
        "name": { "type": "string" },
        "underlying_type": { "type": "string" },
        "constraints": { "$ref": "#/$defs/ValueConstraints" }
      }
    },

    "Endpoint": {
      "type": "object",
      "required": ["param_name", "allowed_types"],
      "properties": {
        "param_name": { "type": "string" },
        "allowed_types": { "type": "array", "items": { "$ref": "#/$defs/TypeRef" } },
        "cardinality": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/Cardinality" }
          ]
        }
      }
    },

    "Cardinality": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        }
      }
    },

    "EdgeConstraints": {
      "type": "object",
      "properties": {
        "no_self": { "type": "boolean", "default": false },
        "acyclic": { "type": "boolean", "default": false },
        "unique": { "type": "boolean", "default": false },
        "symmetric": { "type": "boolean", "default": false },
        "on_kill_source": { "$ref": "#/$defs/LifecycleAction" },
        "on_kill_target": { "$ref": "#/$defs/LifecycleAction" }
      }
    },

    "LifecycleAction": {
      "type": "string",
      "enum": ["cascade", "unlink", "prevent"]
    },

    "Attribute": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/TypeRef" },
        "nullable": { "type": "boolean", "default": false },
        "default": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/ValueNode" }
          ]
        },
        "value_constraints": { "$ref": "#/$defs/ValueConstraints" },
        "modifiers": { "$ref": "#/$defs/AttributeModifiers" }
      }
    },

    "TypeRef": {
      "oneOf": [
        { "type": "object", "required": ["kind", "name"], "properties": { "kind": { "const": "Scalar" }, "name": { "type": "string" } } },
        { "type": "object", "required": ["kind", "name"], "properties": { "kind": { "const": "Node" }, "name": { "type": "string" } } },
        { "type": "object", "required": ["kind", "name"], "properties": { "kind": { "const": "Alias" }, "name": { "type": "string" } } },
        { "type": "object", "required": ["kind", "name"], "properties": { "kind": { "const": "Edge" }, "name": { "type": "string" } } },
        { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "AnyEdge" } } },
        { "type": "object", "required": ["kind", "types"], "properties": { "kind": { "const": "Union" }, "types": { "type": "array", "items": { "$ref": "#/$defs/TypeRef" }, "minItems": 2 } } }
      ]
    },

    "ValueNode": {
      "oneOf": [
        { "type": "object", "required": ["kind", "value"], "properties": { "kind": { "const": "StringLiteral" }, "value": { "type": "string" } } },
        { "type": "object", "required": ["kind", "value"], "properties": { "kind": { "const": "NumberLiteral" }, "value": { "type": "number" } } },
        { "type": "object", "required": ["kind", "value"], "properties": { "kind": { "const": "BooleanLiteral" }, "value": { "type": "boolean" } } },
        { "type": "object", "required": ["kind"], "properties": { "kind": { "const": "Null" } } },
        { "type": "object", "required": ["kind", "fn"], "properties": { "kind": { "const": "Call" }, "fn": { "type": "string" }, "args": { "type": "array", "items": { "$ref": "#/$defs/ValueNode" }, "default": [] } } }
      ]
    },

    "ValueConstraints": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "enum": ["email", "url", "uuid", "slug", "phone"] },
        "pattern": { "type": "string" },
        "enum_values": { "type": "array", "items": { "type": "string" } },
        "length_min": { "type": "integer" },
        "length_max": { "type": "integer" },
        "value_min": { "type": "number" },
        "value_max": { "type": "number" }
      }
    },

    "AttributeModifiers": {
      "type": "object",
      "properties": {
        "unique": { "type": "boolean", "default": false },
        "readonly": { "type": "boolean", "default": false },
        "indexed": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "enum": ["asc", "desc"] }
          ],
          "default": false
        }
      }
    }
  }
}
