{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kernel.astrale.ai/ir/v1",
  "title": "Kernel Schema IR v1",
  "description": "Serialized, fully-resolved graph schema. All type references are qualified IDs. All inheritance is resolved. This is the contract between the compiler and the runtime/SDK.",

  "type": "object",
  "required": ["version", "meta", "builtin_scalars", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "const": "1.0"
    },

    "meta": {
      "type": "object",
      "required": ["generated_at", "source_hash"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "source_hash": {
          "description": "SHA-256 of the concatenated source inputs (prelude + user schema). Allows downstream consumers to detect stale IR.",
          "type": "string"
        }
      }
    },

    "extensions": {
      "description": "Remote schemas this schema depends on.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["uri", "imported_types"],
        "properties": {
          "uri": { "type": "string", "format": "uri" },
          "imported_types": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },

    "builtin_scalars": {
      "description": "The set of compiler-builtin primitive type names. Included for documentation and SDK codegen. The compiler and runtime both know these intrinsically.",
      "type": "array",
      "items": { "type": "string" },
      "examples": [["String", "Int", "Float", "Boolean", "Timestamp", "Bitmask", "ByteString"]]
    },

    "type_aliases": {
      "description": "Resolved type aliases. Included for SDK generation and documentation.",
      "type": "array",
      "items": { "$ref": "#/$defs/TypeAlias" }
    },

    "nodes": {
      "description": "All node types: interfaces (abstract) and classes (concrete).",
      "type": "array",
      "items": { "$ref": "#/$defs/NodeType" }
    },

    "edges": {
      "description": "All edge types (classes with signatures).",
      "type": "array",
      "items": { "$ref": "#/$defs/EdgeType" }
    }
  },

  "$defs": {
    "TypeAlias": {
      "type": "object",
      "required": ["name", "underlying_type"],
      "properties": {
        "name": { "type": "string" },
        "underlying_type": { "type": "string" },
        "constraints": { "$ref": "#/$defs/ValueConstraints" }
      }
    },

    "NodeType": {
      "type": "object",
      "required": ["name", "abstract", "attributes"],
      "properties": {
        "name": { "type": "string" },
        "abstract": {
          "description": "true = interface, false = class.",
          "type": "boolean"
        },
        "implements": {
          "description": "Direct parent interfaces (by name). Not the transitive closure.",
          "type": "array",
          "items": { "type": "string" }
        },
        "attributes": {
          "description": "Own attributes only.",
          "type": "array",
          "items": { "$ref": "#/$defs/Attribute" }
        },
        "origin": {
          "description": "Source URI if imported via extend.",
          "type": "string",
          "format": "uri"
        }
      }
    },

    "EdgeType": {
      "type": "object",
      "required": ["name", "endpoints", "attributes", "constraints"],
      "properties": {
        "name": { "type": "string" },
        "endpoints": {
          "description": "Ordered, named parameters. Preserves names and per-endpoint cardinality.",
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/Endpoint" }
        },
        "attributes": {
          "type": "array",
          "items": { "$ref": "#/$defs/Attribute" }
        },
        "constraints": { "$ref": "#/$defs/EdgeConstraints" },
        "origin": {
          "type": "string",
          "format": "uri"
        }
      }
    },

    "Endpoint": {
      "type": "object",
      "required": ["param_name", "allowed_types"],
      "properties": {
        "param_name": { "type": "string" },
        "allowed_types": {
          "description": "Discriminated type references for this endpoint.",
          "type": "array",
          "items": { "$ref": "#/$defs/TypeRef" }
        },
        "cardinality": {
          "description": "Null = unconstrained.",
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/Cardinality" }]
        }
      }
    },

    "Cardinality": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": {
          "description": "null = unbounded.",
          "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        }
      }
    },

    "EdgeConstraints": {
      "type": "object",
      "properties": {
        "no_self": { "type": "boolean", "default": false },
        "acyclic": { "type": "boolean", "default": false },
        "unique": { "type": "boolean", "default": false },
        "symmetric": { "type": "boolean", "default": false },
        "on_kill_source": { "$ref": "#/$defs/LifecycleAction" },
        "on_kill_target": { "$ref": "#/$defs/LifecycleAction" }
      }
    },

    "LifecycleAction": {
      "type": "string",
      "enum": ["cascade", "unlink", "prevent"]
    },

    "Attribute": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "$ref": "#/$defs/TypeRef" },
        "nullable": { "type": "boolean", "default": false },
        "default": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/ValueNode" }]
        },
        "value_constraints": { "$ref": "#/$defs/ValueConstraints" },
        "modifiers": { "$ref": "#/$defs/AttributeModifiers" }
      }
    },

    "TypeRef": {
      "description": "Discriminated type reference.",
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "Scalar" },
            "name": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "Node" },
            "name": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "Alias" },
            "name": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "Edge" },
            "name": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "AnyEdge" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "types"],
          "properties": {
            "kind": { "const": "Union" },
            "types": {
              "type": "array",
              "items": { "$ref": "#/$defs/TypeRef" },
              "minItems": 2
            }
          }
        }
      ]
    },

    "ValueNode": {
      "description": "Structured default value. Consumers never parse strings.",
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "StringLiteral" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "NumberLiteral" },
            "value": { "type": "number" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "BooleanLiteral" },
            "value": { "type": "boolean" }
          }
        },
        {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": { "const": "Null" }
          }
        },
        {
          "type": "object",
          "required": ["kind", "fn"],
          "properties": {
            "kind": { "const": "Call" },
            "fn": { "type": "string" },
            "args": {
              "type": "array",
              "items": { "$ref": "#/$defs/ValueNode" },
              "default": []
            }
          }
        }
      ]
    },

    "ValueConstraints": {
      "type": "object",
      "properties": {
        "format": { "type": "string", "enum": ["email", "url", "uuid", "slug", "phone"] },
        "pattern": { "type": "string" },
        "enum_values": { "type": "array", "items": { "type": "string" } },
        "length_min": { "type": "integer" },
        "length_max": { "type": "integer" },
        "value_min": { "type": "number" },
        "value_max": { "type": "number" }
      }
    },

    "AttributeModifiers": {
      "type": "object",
      "properties": {
        "unique": { "type": "boolean", "default": false },
        "readonly": { "type": "boolean", "default": false },
        "indexed": {
          "oneOf": [{ "type": "boolean" }, { "type": "string", "enum": ["asc", "desc"] }],
          "default": false
        }
      }
    }
  }
}
