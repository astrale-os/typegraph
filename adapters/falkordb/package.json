{
  "name": "@astrale/typegraph-adapter-falkordb",
  "version": "0.1.0",
  "description": "FalkorDB adapter for TypeGraph - Redis-based graph database",
  "keywords": [
    "cypher",
    "database",
    "falkordb",
    "graph",
    "redis",
    "type-safe",
    "typegraph",
    "typescript"
  ],
  "license": "MIT",
  "author": "Astrale",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run __tests__/integration",
    "test:unit": "vitest run __tests__/transform __tests__/error-handling",
    "test:perf": "vitest run __tests__/performance",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f",
    "example:basic": "tsx examples/basic.ts",
    "example:mutations": "tsx examples/mutations.ts",
    "example:hierarchy": "tsx examples/hierarchy.ts"
  },
  "dependencies": {
    "@astrale/typegraph-client": "workspace:*",
    "falkordb": "^6.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript/native-preview": "latest",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "~6.0.1-rc",
    "vitest": "^2.1.8",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "falkordb": "^6.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
