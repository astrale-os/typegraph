{
  "name": "kernel-lang",
  "displayName": "Kernel Schema Language",
  "description": "Language support for .gsl schema files — syntax highlighting, diagnostics, hover, go-to-definition, completions, and outline.",
  "version": "0.1.0",
  "publisher": "astrale",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "gsl",
        "aliases": [
          "Kernel",
          "gsl"
        ],
        "extensions": [
          ".gsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "gsl",
        "scopeName": "source.gsl",
        "path": "./syntaxes/gsl.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "gsl",
        "scopes": {
          "type": [
            "entity.name.type.gsl"
          ],
          "class": [
            "entity.name.type.class.gsl"
          ],
          "interface": [
            "entity.name.type.interface.gsl"
          ],
          "enum": [
            "entity.name.type.alias.gsl"
          ],
          "property": [
            "variable.other.property.gsl"
          ],
          "variable": [
            "entity.name.type.edge.gsl"
          ],
          "keyword": [
            "keyword.control.gsl"
          ],
          "string": [
            "string.quoted.double.gsl"
          ],
          "number": [
            "constant.numeric.gsl"
          ],
          "operator": [
            "keyword.operator.gsl"
          ],
          "comment": [
            "comment.line.gsl"
          ],
          "decorator": [
            "entity.other.attribute-name.modifier.gsl"
          ]
        }
      }
    ],
    "configuration": {
      "title": "Kernel",
      "properties": {
        "gsl.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server."
        }
      }
    }
  },
  "scripts": {
    "build:ext": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
    "build:server": "cd ../compiler && node scripts/bundle-server.mjs ../vscode/server",
    "build": "npm run build:server && npm run build:ext",
    "watch": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --watch --sourcemap",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies",
    "install-local": "npm run package && code --install-extension kernel-lang-0.1.0.vsix"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0"
  }
}
