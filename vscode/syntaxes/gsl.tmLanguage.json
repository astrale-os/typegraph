{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kernel Schema Language",
  "scopeName": "source.gsl",
  "patterns": [
    { "include": "#comment" },
    { "include": "#extend" },
    { "include": "#type-alias" },
    { "include": "#interface" },
    { "include": "#class" },
    { "include": "#data-decl" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keywords" }
  ],
  "repository": {
    "comment": {
      "match": "--.*$",
      "name": "comment.line.double-dash.gsl"
    },

    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.gsl",
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.gsl"
        }
      ]
    },

    "number": {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.gsl"
    },

    "keywords": {
      "patterns": [
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.gsl"
        },
        {
          "match": "\\b(any)\\b",
          "name": "constant.language.gsl"
        }
      ]
    },

    "extend": {
      "begin": "\\b(extend)\\b",
      "beginCaptures": { "1": { "name": "keyword.control.extend.gsl" } },
      "end": "(?<=})",
      "patterns": [{ "include": "#string" }, { "include": "#brace-block" }]
    },

    "type-alias": {
      "begin": "\\b(type)\\s+([A-Z]\\w*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.type.gsl" },
        "2": { "name": "entity.name.type.alias.gsl" }
      },
      "end": "(?=\\b(?:class|interface|type|extend|data)\\b|$(?!\\s))",
      "patterns": [
        { "include": "#modifier-block" },
        { "include": "#type-reference" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#operators" },
        { "include": "#comment" }
      ]
    },

    "interface": {
      "begin": "\\b(interface)\\s+([A-Z]\\w*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.interface.gsl" },
        "2": { "name": "entity.name.type.interface.gsl" }
      },
      "end": "(?<=})",
      "patterns": [
        { "include": "#extends-clause" },
        { "include": "#body" },
        { "include": "#comment" }
      ]
    },

    "class": {
      "begin": "\\b(class)\\s+(\\w+)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.class.gsl" },
        "2": { "name": "entity.name.type.class.gsl" }
      },
      "end": "(?<=}|\\])|(?=\\b(?:class|interface|type|extend)\\b)",
      "patterns": [
        { "include": "#signature" },
        { "include": "#extends-clause" },
        { "include": "#modifier-block" },
        { "include": "#body" },
        { "include": "#comment" }
      ]
    },

    "data-decl": {
      "begin": "\\b(data)\\s+([A-Z]\\w*)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.data.gsl" },
        "2": { "name": "entity.name.type.data.gsl" }
      },
      "end": "(?<=})|(?=\\b(?:class|interface|type|extend|data)\\b)|(?=$)",
      "patterns": [
        { "include": "#body" },
        { "include": "#type-reference" },
        { "include": "#operators" },
        { "include": "#comment" }
      ]
    },

    "fn-decl": {
      "begin": "\\b(fn)\\s+(\\w+)",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.fn.gsl" },
        "2": { "name": "entity.name.function.gsl" }
      },
      "end": "(?=[,}]|$)",
      "patterns": [
        { "include": "#signature" },
        { "include": "#type-expression" },
        { "include": "#operators" },
        { "include": "#comment" }
      ]
    },

    "signature": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.paren.open.gsl" } },
      "endCaptures": { "0": { "name": "punctuation.paren.close.gsl" } },
      "patterns": [
        { "include": "#param" },
        { "include": "#type-expression" },
        { "include": "#comment" }
      ]
    },

    "param": {
      "match": "(\\w+)\\s*(:)",
      "captures": {
        "1": { "name": "variable.parameter.gsl" },
        "2": { "name": "punctuation.separator.gsl" }
      }
    },

    "extends-clause": {
      "begin": "(:)\\s*",
      "beginCaptures": { "1": { "name": "punctuation.separator.extends.gsl" } },
      "end": "(?=[{\\[\\(]|$)",
      "patterns": [
        {
          "match": "\\b([A-Z]\\w*)\\b",
          "name": "entity.other.inherited-class.gsl"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.gsl"
        }
      ]
    },

    "body": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.brace.open.gsl" } },
      "endCaptures": { "0": { "name": "punctuation.brace.close.gsl" } },
      "patterns": [
        { "include": "#fn-decl" },
        { "include": "#data-decl" },
        {
          "match": "\\b(data)\\s+([A-Z]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.data.gsl" },
            "2": { "name": "entity.name.type.data.gsl" }
          }
        },
        { "include": "#attribute" },
        { "include": "#comment" }
      ]
    },

    "attribute": {
      "begin": "(\\w+)\\s*(:)",
      "beginCaptures": {
        "1": { "name": "variable.other.property.gsl" },
        "2": { "name": "punctuation.separator.gsl" }
      },
      "end": "(?=[,}])",
      "patterns": [
        { "include": "#modifier-block" },
        { "include": "#default-value" },
        { "include": "#type-expression" },
        { "include": "#comment" }
      ]
    },

    "type-expression": {
      "patterns": [
        { "include": "#edge-ref-type" },
        { "include": "#type-reference" },
        {
          "match": "\\?",
          "name": "keyword.operator.optional.gsl"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.union.gsl"
        }
      ]
    },

    "edge-ref-type": {
      "match": "\\b(edge)\\s*(<)\\s*(\\w+)\\s*(>)",
      "captures": {
        "1": { "name": "keyword.other.edge.gsl" },
        "2": { "name": "punctuation.angle.open.gsl" },
        "3": { "name": "entity.name.type.gsl" },
        "4": { "name": "punctuation.angle.close.gsl" }
      }
    },

    "type-reference": {
      "match": "\\b([A-Z]\\w*)\\b",
      "name": "entity.name.type.gsl"
    },

    "modifier-block": {
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": { "0": { "name": "punctuation.bracket.open.gsl" } },
      "endCaptures": { "0": { "name": "punctuation.bracket.close.gsl" } },
      "patterns": [
        { "include": "#modifier-keywords" },
        { "include": "#modifier-arrow" },
        { "include": "#modifier-range-op" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#operators" },
        { "include": "#comment" },
        {
          "begin": "\\[",
          "end": "\\]",
          "patterns": [
            { "include": "#string" },
            { "match": ",", "name": "punctuation.separator.comma.gsl" }
          ]
        }
      ]
    },

    "modifier-keywords": {
      "match": "\\b(unique|readonly|indexed|no_self|acyclic|symmetric|format|match|in|length|on_kill_source|on_kill_target|cascade|unlink|prevent|asc|desc)\\b",
      "name": "entity.other.attribute-name.modifier.gsl"
    },

    "modifier-arrow": {
      "match": "->",
      "name": "keyword.operator.arrow.gsl"
    },

    "modifier-range-op": {
      "match": ">=|<=|\\.\\.",
      "name": "keyword.operator.range.gsl"
    },

    "default-value": {
      "begin": "(=)\\s*",
      "beginCaptures": { "1": { "name": "keyword.operator.assignment.gsl" } },
      "end": "(?=[,}\\]])",
      "patterns": [
        { "include": "#string" },
        { "include": "#number" },
        {
          "match": "\\b(true|false|null)\\b",
          "name": "constant.language.gsl"
        },
        {
          "match": "(\\w+)(\\()(\\))",
          "captures": {
            "1": { "name": "entity.name.function.gsl" },
            "2": { "name": "punctuation.paren.open.gsl" },
            "3": { "name": "punctuation.paren.close.gsl" }
          }
        }
      ]
    },

    "operators": {
      "match": "->|\\.\\.|\\.\\.|>=|<=|=|\\||\\*|\\?",
      "name": "keyword.operator.gsl"
    },

    "brace-block": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.brace.open.gsl" } },
      "endCaptures": { "0": { "name": "punctuation.brace.close.gsl" } },
      "patterns": [
        {
          "match": "\\b(\\w+)\\b",
          "name": "entity.name.type.gsl"
        },
        { "match": ",", "name": "punctuation.separator.comma.gsl" }
      ]
    }
  }
}
